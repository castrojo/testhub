{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "github-actions",
    "custom.regex"
  ],
  "automerge": true,
  "automergeType": "pr",
  "platformAutomerge": true,
  "labels": [
    "dependencies",
    "automated"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "matchFileNames": [
        "flatpaks/**/release.yaml",
        "flatpaks/**/manifest.yaml"
      ],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "matchUpdateTypes": [
        "major"
      ],
      "automerge": false
    },
    {
      "matchPackageNames": [
        "quay.io/jlebon/chunkah"
      ],
      "automerge": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update release.yaml bundle-repack packages: version, url, and sha256 fields (allows intervening comment/config lines between version and url)",
      "managerFilePatterns": [
        "/^flatpaks/[^/]+/release\\.yaml$/"
      ],
      "matchStrings": [
        "version:\\s*(?<currentValue>v?[0-9]+\\.[0-9.]+[^\\n]*)\\n(?:[^\\n]*\\n){0,5}url:\\s*(?<urlPrefix>https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/)v?[0-9]+\\.[0-9.]+[^/]*/(?<urlSuffix>[^\\n]+)\\nsha256:\\s*(?<currentDigest>[0-9a-f]{64})"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced",
      "autoReplaceStringTemplate": "version: {{{newValue}}}\nurl: {{{urlPrefix}}}{{{newValue}}}/{{{urlSuffix}}}\nsha256: {{{newDigest}}}"
    },
    {
      "customType": "regex",
      "description": "Update monkey-bubble GitLab release.yaml (version, url, sha256)",
      "managerFilePatterns": [
        "/^flatpaks\/monkey-bubble\/release\\.yaml$/"
      ],
      "matchStrings": [
        "version:\\s*(?<currentValue>v?[0-9]+\\.[0-9]+\\.[0-9]+)\\n(?:[^\\n]*\\n){0,5}url:\\s*https://gitlab\\.com/api/v4/projects/80424238/packages/generic/monkey-bubble/v?[0-9]+\\.[0-9]+\\.[0-9]+/(?<urlSuffix>[^\\n]+)\\nsha256:\\s*(?<currentDigest>[0-9a-f]{64})"
      ],
      "datasourceTemplate": "gitlab-tags",
      "depNameTemplate": "cschalle/monkey-bubble",
      "registryUrlTemplate": "https://gitlab.com",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "autoReplaceStringTemplate": "version: {{{newValue}}}\nurl: https://gitlab.com/api/v4/projects/80424238/packages/generic/monkey-bubble/{{{newValue}}}/{{{urlSuffix}}}\nsha256: {{{newDigest}}}"
    },
    {
      "customType": "regex",
      "description": "Update wmdock GitLab archive manifest (x-version, url, sha256)",
      "managerFilePatterns": [
        "/^flatpaks\/wmdock\/manifest\\.yaml$/"
      ],
      "matchStrings": [
        "x-version:\\s*[\"']?(?<currentValue>[^\"'\\n]+)[\"']?(?:[^\\n]*\\n){0,80}\\s*url:\\s*https://gitlab\\.com/cschalle/wmdock/-/archive/v[^\\s/]+/wmdock-v[^\\s/]+\\.tar\\.gz\\n\\s*sha256:\\s*(?<currentDigest>[0-9a-f]{64})"
      ],
      "datasourceTemplate": "gitlab-tags",
      "depNameTemplate": "cschalle/wmdock",
      "registryUrlTemplate": "https://gitlab.com",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "autoReplaceStringTemplate": "x-version: \"{{{newValue}}}\"\nurl: https://gitlab.com/cschalle/wmdock/-/archive/v{{{newValue}}}/wmdock-v{{{newValue}}}.tar.gz\nsha256: {{{newDigest}}}"
    },
    {
      "customType": "regex",
      "description": "Update xmms-resuscitated build tags in release.yaml",
      "managerFilePatterns": [
        "/^flatpaks\/xmms-resuscitated\/release\\.yaml$/"
      ],
      "matchStrings": [
        "version:\\s*(?<currentValue>build-[0-9]+)\\n(?:[^\\n]*\\n){0,8}url:\\s*https://gitlab\\.com/cschalle/xmms-resuscitated/-/jobs/artifacts/build-[0-9]+/raw/(?<urlSuffix>[^\\n]+)\\nsha256:\\s*(?<currentDigest>[0-9a-f]{64})"
      ],
      "datasourceTemplate": "gitlab-tags",
      "depNameTemplate": "cschalle/xmms-resuscitated",
      "registryUrlTemplate": "https://gitlab.com",
      "versioningTemplate": "regex:^build-(?<major>\\d+)$",
      "autoReplaceStringTemplate": "version: {{{newValue}}}\nurl: https://gitlab.com/cschalle/xmms-resuscitated/-/jobs/artifacts/{{{newValue}}}/raw/{{{urlSuffix}}}\nsha256: {{{newDigest}}}"
    },
    {
      "customType": "regex",
      "description": "Update all Saturn manifest git source commits to latest default-branch HEAD",
      "managerFilePatterns": [
        "/^flatpaks\/saturn\/manifest\\.yaml$/"
      ],
      "matchStrings": [
        "-\\s*type:\\s*git\\n\\s*url:\\s*(?<packageName>https://[^\\s]+)\\n\\s*commit:\\s*(?<currentDigest>[0-9a-f]{40})"
      ],
      "currentValueTemplate": "HEAD",
      "datasourceTemplate": "git-refs",
      "depNameTemplate": "{{{packageName}}}",
      "autoReplaceStringTemplate": "- type: git\n        url: {{{packageName}}}\n        commit: {{{newDigest}}}"
    },
    {
      "customType": "regex",
      "description": "Update manifest.yaml GitHub archive tags: x-version, url, and sha256 (fields may be non-adjacent)",
      "managerFilePatterns": [
        "/^flatpaks/[^/]+/manifest\\.yaml$/"
      ],
      "matchStrings": [
        "x-version:\\s*[\"']?(?<currentValue>[^\"'\\n]+)[\"']?(?:[^\\n]*\\n){0,120}\\s*url:\\s*(?<urlPrefix>https://github\\.com/(?<depName>[^/]+/[^/]+)/archive/refs/tags/v)[^\\s/]+(?<urlSuffix>\\.tar\\.gz)\\n\\s*sha256:\\s*(?<currentDigest>[0-9a-f]{64})"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "autoReplaceStringTemplate": "x-version: \"{{{newValue}}}\"\nurl: {{{urlPrefix}}}{{{newValue}}}{{{urlSuffix}}}\nsha256: {{{newDigest}}}"
    },
    {
      "customType": "regex",
      "description": "Update manifest.yaml GitHub release assets with versioned filenames (x-version, url, sha256)",
      "managerFilePatterns": [
        "/^flatpaks/[^/]+/manifest\\.yaml$/"
      ],
      "matchStrings": [
        "x-version:\\s*[\"']?(?<currentValue>[^\"'\\n]+)[\"']?(?:[^\\n]*\\n){0,120}\\s*url:\\s*(?<urlPrefix>https://github\\.com/(?<depName>[^/]+/[^/]+)/releases/download/v)[^/\\n]+/(?<filenamePrefix>[^\\n]*?)v[^/\\n]+(?<filenameSuffix>\\.[^\\n]+)\\n\\s*sha256:\\s*(?<currentDigest>[0-9a-f]{64})"
      ],
      "datasourceTemplate": "github-releases",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.*)$",
      "autoReplaceStringTemplate": "x-version: \"{{{newValue}}}\"\nurl: {{{urlPrefix}}}{{{newValue}}}/{{{filenamePrefix}}}v{{{newValue}}}{{{filenameSuffix}}}\nsha256: {{{newDigest}}}"
    },
    {
      "customType": "regex",
      "description": "Update chunkah container image tag in Justfile and build.yml",
      "managerFilePatterns": [
        "/^Justfile$/",
        "/^\\.github/workflows/build\\.yml$/"
      ],
      "matchStrings": [
        "quay\\.io/jlebon/chunkah:(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "docker",
      "depNameTemplate": "quay.io/jlebon/chunkah",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "description": "Update yq version in Justfile",
      "managerFilePatterns": [
        "/^Justfile$/"
      ],
      "matchStrings": [
        "YQ_VERSION=\"(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "mikefarah/yq",
      "versioningTemplate": "semver-coerced"
    },
    {
      "customType": "regex",
      "description": "Update oras version in Justfile",
      "managerFilePatterns": [
        "/^Justfile$/"
      ],
      "matchStrings": [
        "ORAS_VERSION=\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "oras-project/oras",
      "versioningTemplate": "semver-coerced",
      "extractVersionTemplate": "^v?(?<version>.*)$"
    },
    {
      "customType": "regex",
      "description": "Update flathub-infra CI container image tag and digest in build.yml",
      "managerFilePatterns": [
        "/^\\.github/workflows/build\\.yml$/"
      ],
      "matchStrings": [
        "image: ghcr\\.io/flathub-infra/flatpak-github-actions:(?<currentValue>[a-z0-9._-]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "depNameTemplate": "ghcr.io/flathub-infra/flatpak-github-actions",
      "datasourceTemplate": "docker",
      "versioningTemplate": "loose"
    }
  ]
}
